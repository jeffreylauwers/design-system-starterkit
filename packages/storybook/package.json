{
  "name": "@dsn-starter-kit/storybook",
  "version": "1.0.0",
  "private": true,
  "description": "Documentation and component showcase for the design system",
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "storybook build -o dist",
    "build:gh-pages": "STORYBOOK_BASE_PATH=/design-system-starter-kit/ storybook build -o dist",
    "test-storybook": "test-storybook",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "design-system",
    "storybook",
    "documentation"
  ],
  "author": "Jeffrey Lauwers",
  "license": "MIT",
  "dependencies": {
    "@dsn-starter-kit/components-react": "workspace:*",
    "@dsn-starter-kit/core": "workspace:*",
    "@dsn-starter-kit/design-tokens": "workspace:*"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-links": "^10.3.6",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/react": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@storybook/test-runner": "^0.24.3",
    "playwright": "^1.58.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^10.3.6",
    "storybook-multilevel-sort": "^2.1.0",
    "vite": "^6.0.0",
    "vite-plugin-svgr": "^5.0.0",
    "eslint-plugin-storybook": "10.3.6",
    "@storybook/addon-docs": "^10.3.6"
  }
}
