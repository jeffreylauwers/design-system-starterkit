        "padding-block-end": {
          "$value": "{dsn.space.block.xl}",
          "$type": "spacing",
          "$description": "Onderkant padding van de footer (16px)"
        },
        "padding-inline": {
          "$value": "{dsn.space.inline.xl}",
          "$type": "spacing",
