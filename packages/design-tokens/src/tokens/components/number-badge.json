{
  "dsn": {
    "number-badge": {
      "font-size": {
        "$value": "{dsn.text.font-size.sm}",
        "$type": "fontSize",
        "$description": "NumberBadge font size — zelfde schaal als StatusBadge (kleinst beschikbare stap)"
      },
      "line-height": {
        "$value": "{dsn.text.line-height.sm}",
