      "font-family": {
        "default": {
          "$value": "IBM Plex Sans, sans-serif",
          "$description": "Default font family for body text"
        },
        "monospace": {
          "$value": "IBM Plex Mono, monospace",
          "$description": "Monospace font family for code"
        }
      },
      "font-weight": {
        "default": {
          "$value": "400",
          "$description": "Regular weight"
        },
        "bold": {
          "$value": "700",
          "$description": "Bold weight"
        }
      },
      "max-inline-size": {
