        "md": {
          "$value": "20ch",
          "$type": "dimension",
          "$description": "Medium width - for medium inputs (e.g., date dd/mm/yyyy, phone number)"
        },
        "lg": {
          "$value": "32ch",
          "$type": "dimension",
          "$description": "Large width (default) - for standard inputs (e.g., name, email)"
        },
        "xl": {
